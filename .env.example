# StudyOps local development environment

# Local storage paths. Relative paths are resolved from the project root.
STUDYOPS_OBSIDIAN_VAULT=data/obsidian_vault
STUDYOPS_CHROMA_DIR=data/chroma
STUDYOPS_SQLITE_PATH=data/sqlite/studyops.db

# Local AI Studio mode, when running ADK model calls.
# GOOGLE_API_KEY=
# GOOGLE_GENAI_USE_VERTEXAI=False

# Vertex AI mode, when deploying later.
# GOOGLE_GENAI_USE_VERTEXAI=True
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=global

# Frontend CORS origins allowed to call the local backend bridge.
ALLOW_ORIGINS=https://studyops-agent.vercel.app,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000,null

# Keep cloud telemetry disabled for the personal local backend bridge.
STUDYOPS_OTEL_TO_CLOUD=False
